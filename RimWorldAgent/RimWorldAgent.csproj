<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <AssemblyName>RimWorldAgent</AssemblyName>
    <RootNamespace>RimWorldAgent</RootNamespace>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <StartupObject>RimWorldAgent.Program</StartupObject>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <OutputPath>..\publish\RimWorldAgent\1.6\Assemblies\</OutputPath>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <OutputPath>..\publish\RimWorldAgent\1.6\Assemblies\</OutputPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Assembly-CSharp">
      <HintPath>F:\SteamLibrary\steamapps\common\RimWorld\RimWorldWin64_Data\Managed\Assembly-CSharp.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>F:\SteamLibrary\steamapps\common\RimWorld\RimWorldWin64_Data\Managed\UnityEngine.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>F:\SteamLibrary\steamapps\common\RimWorld\RimWorldWin64_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>F:\SteamLibrary\steamapps\common\RimWorld\RimWorldWin64_Data\Managed\UnityEngine.IMGUIModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.TextRenderingModule">
      <HintPath>F:\SteamLibrary\steamapps\common\RimWorld\RimWorldWin64_Data\Managed\UnityEngine.TextRenderingModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Net.Http" />
    <Reference Include="System.ValueTuple" HintPath="$(MSBuildProjectDirectory)\..\RimWorldMCP\System.ValueTuple.dll">
      <Private>True</Private>
    </Reference>
    <ProjectReference Include="..\SimpleMspServer\SimpleMspServer.csproj" />
  </ItemGroup>

  <!-- 构建前清空根 publish -->
  <Target Name="CleanPublish" BeforeTargets="BeforeBuild">
    <RemoveDir Directories="..\publish\RimWorldAgent\1.6\Assemblies" ContinueOnError="true" />
  </Target>

  <!-- 从 resource/ 复制 MOD 元数据到根 publish -->
  <Target Name="CopyAbout" AfterTargets="Build">
    <Copy SourceFiles="$(MSBuildProjectDirectory)\resource\About\About.xml"
          DestinationFolder="..\publish\RimWorldAgent\About\" />
  </Target>
  <Target Name="CopySkills" AfterTargets="Build">
    <ItemGroup>
      <SkillFiles Include="$(MSBuildProjectDirectory)\resource\Skills\*.md" />
    </ItemGroup>
    <Copy SourceFiles="@(SkillFiles)"
          DestinationFolder="..\publish\RimWorldAgent\Skills\" />
  </Target>
  <Target Name="CopyReadme" AfterTargets="Build">
    <Copy SourceFiles="$(MSBuildProjectDirectory)\README.md"
          DestinationFolder="..\publish\RimWorldAgent\"
          Condition="Exists('$(MSBuildProjectDirectory)\README.md')" />
  </Target>
  <Target Name="CopyCcCompanion" AfterTargets="Build">
    <MakeDir Directories="..\publish\RimWorldAgent\cc-companion" />
    <Exec Command="xcopy &quot;$(MSBuildProjectDirectory)\cc-companion\*&quot; &quot;..\publish\RimWorldAgent\cc-companion\&quot; /S /Y /I /EXCLUDE:$(MSBuildProjectDirectory)\cc-companion\.copyignore"
          Condition="Exists('$(MSBuildProjectDirectory)\cc-companion')"
          IgnoreExitCode="true" />
  </Target>
</Project>
